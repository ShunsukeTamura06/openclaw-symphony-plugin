# Symphony Pod (web/API) base URL — e.g. https://acme.symphony.com
OPENCLAW_SYMPHONY_POD_URL=

# Symphony Agent base URL — e.g. https://acme-agent.symphony.com
OPENCLAW_SYMPHONY_AGENT_URL=

# Bot service-account username (the value registered in the Symphony admin portal)
OPENCLAW_SYMPHONY_BOT_USERNAME=

# Absolute path to the bot's RSA private key (PKCS#8 PEM)
OPENCLAW_SYMPHONY_PRIVATE_KEY_PATH=/absolute/path/to/bot-private.pem

# Optional: override JWT lifetime (seconds). Default 290.
# OPENCLAW_SYMPHONY_JWT_TTL_SEC=290

# Optional: override Datafeed v5 long-poll timeout (seconds). Default 30.
# OPENCLAW_SYMPHONY_DATAFEED_TIMEOUT_SEC=30

# Optional: target stream/IM ID used by smoke-send.ts
OPENCLAW_SYMPHONY_SMOKE_STREAM_ID=
